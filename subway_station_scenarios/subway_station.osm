  <tag k="charge" v="12.00 CNY"/>
  <tag k="description" v="分段计价，济南公共交通集团有限公司运行时间济南公交刷卡9折折扣，济南好运巴士公共交通有限公司运行时间无优惠，全程五段，分段计价，最高票价12元，同一区段内同一票价，跨区段按所跨区段票价总和计票：区段一(3元)：公交营运中心 - 青龙山长途客运站、区段二(2元)：青龙山长途客运站 - 邢村立交桥、区段三(2元)：邢村立交桥 - 山东职业学院、区段四(2元)：山东职业学院 - 鹅庄、区段五(3元)：鹅庄 - 章丘（技师学院）"/>
  <tag k="description_1" v="济南公交车辆发车时间6:00－9:00、12:30－15:30；山东交运车辆发车时间:9:30－12:00、16:00－末班"/>
  <tag k="fee" v="yes"/>
  <tag k="from" v="公交营运中心"/>
  <tag k="name" v="K301路：公交营运中心 -&gt; 章丘"/>
  <tag k="name:en" v="Bus K301: Bus Service Center -&gt; Zhangqiu"/>
  <tag k="name:zh" v="K301路：公交营运中心 -&gt; 章丘"/>
  <tag k="network" v="济南公交"/>
  <tag k="network:en" v="Jinan Public Transport"/>
