  <tag k="network:wikipedia" v="zh:济南公交"/>
  <tag k="network:zh" v="济南公交"/>
  <tag k="opening_hours" v="Jan-Feb 06:00-19:00; Mar-Oct 06:00-18:30; Nov-Dec 06:00-19:00"/>
  <tag k="operator" v="济南公共交通集团有限公司\济南好运巴士公共交通有限公司"/>
  <tag k="operator:zh" v="济南公共交通集团有限公司\济南好运巴士公共交通有限公司"/>
